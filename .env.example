# Supabase Configuration
# Get these values from your Supabase Dashboard:
# 1. Go to Settings > API
# 2. Copy the Project URL for SUPABASE_URL
# 3. Copy the anon/public key for SUPABASE_KEY (or service_role key for backend operations)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# Discord Configuration
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=123456789012345678

# Discord OAuth2 Configuration
# Get these values from Discord Developer Portal:
# 1. Go to https://discord.com/developers/applications
# 2. Select your application
# 3. Go to OAuth2 section
# 4. Copy Client ID and Client Secret
# 5. Add redirect URI: http://localhost:8000/api/auth/discord/callback (dev) or https://yourdomain.com/api/auth/discord/callback (prod)
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:8000/api/auth/discord/callback

# LLM (Groq) Configuration
GROQ_API_KEY=your_groq_api_key

# LLM Rate Limit Configuration (Free Tier: 30 RPM, 14,400 RPD)
# Concurrent API requests (default: 2)
# Lower values = slower but safer, higher values = faster but may hit rate limits
LLM_CONCURRENT_LIMIT=2

# Delay between requests in seconds (default: 4)
# Calculation: (60 seconds / 30 RPM) × concurrent_limit = 4 seconds
# Increase this if you frequently hit rate limits (429 errors)
LLM_REQUEST_DELAY=4

# Maximum retries for failed API calls (default: 2)
LLM_MAX_RETRIES=2

# Timeout for API calls in seconds (default: 30)
LLM_TIMEOUT=30

# RSS Configuration
# Number of days to look back when fetching articles (default: 7)
RSS_FETCH_DAYS=7

# Scheduler Configuration
# CRON expression for background job schedule (default: "0 */6 * * *" - every 6 hours)
# Format: minute hour day month day_of_week
# Examples:
#   "0 */6 * * *"   - Every 6 hours
#   "0 0 * * *"     - Daily at midnight
#   "0 9 * * 1"     - Every Monday at 9am
#   "*/30 * * * *"  - Every 30 minutes
SCHEDULER_CRON=0 */6 * * *

# Timezone for scheduler (optional, defaults to Asia/Taipei)
# Use IANA timezone names (e.g., "America/New_York", "Europe/London", "UTC")
# SCHEDULER_TIMEZONE=Asia/Taipei

# Batch Processing Configuration
# Maximum number of articles to process per batch (default: 50)
# Smaller batches use less memory but take longer overall
BATCH_SIZE=50

# Threshold for splitting into multiple batches (default: 100)
# When article count exceeds this, they will be split into batches
BATCH_SPLIT_THRESHOLD=100

# JWT Configuration
# Secret key for signing JWT tokens (MUST be at least 32 characters)
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_at_least_32_characters_long
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DAYS=7

# CORS Configuration
# Comma-separated list of allowed origins for CORS
# Development: http://localhost:3000,http://localhost:8000
# Production: https://yourdomain.com
CORS_ORIGINS=http://localhost:3000

# Rate Limiting Configuration
# Maximum requests per minute for unauthenticated users (default: 100)
RATE_LIMIT_PER_MINUTE_UNAUTH=100

# Maximum requests per minute for authenticated users (default: 300)
RATE_LIMIT_PER_MINUTE_AUTH=300

# Security Configuration
# Set to true in production to require HTTPS for cookies (default: true)
# Set to false in development (default: false for local testing)
COOKIE_SECURE=false

