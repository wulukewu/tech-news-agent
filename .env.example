# ============================================
# Tech News Agent - Environment Variables
# ============================================
#
# 使用說明:
# 1. 複製此檔案: cp .env.example .env
# 2. 填入你的實際值
# 3. 不要提交 .env 到 Git
#
# ============================================

# ============================================
# BACKEND CONFIGURATION
# ============================================

# --------------------------------------------
# Supabase Configuration (必填)
# --------------------------------------------
# 取得方式:
# 1. 前往 https://supabase.com/dashboard
# 2. 選擇你的專案
# 3. Settings > API
# 4. 複製 Project URL 和 service_role key (不是 anon key)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key-here

# --------------------------------------------
# Discord Bot Configuration (必填)
# --------------------------------------------
# 取得方式:
# 1. 前往 https://discord.com/developers/applications
# 2. 建立或選擇應用程式
# 3. Bot > Copy Token
# 4. 在 Discord 中右鍵點擊頻道 > 複製 ID（選填，改用 DM 通知）
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=123456789012345678  # 選填：如果要保留頻道通知功能

# --------------------------------------------
# Discord OAuth2 Configuration (必填)
# --------------------------------------------
# 取得方式:
# 1. 同上 Discord 應用程式
# 2. OAuth2 > Copy Client ID and Client Secret
# 3. 在 Redirects 中新增:
#    開發: http://localhost:8000/api/auth/discord/callback
#    正式: https://api.yourdomain.com/api/auth/discord/callback
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
DISCORD_REDIRECT_URI=http://localhost:8000/api/auth/discord/callback

# --------------------------------------------
# LLM (Groq) Configuration (必填)
# --------------------------------------------
# 取得方式:
# 1. 前往 https://console.groq.com/keys
# 2. 建立新的 API Key
GROQ_API_KEY=your_groq_api_key_here

# --------------------------------------------
# LLM Rate Limit Configuration (選填)
# --------------------------------------------
# Free Tier 限制: 30 RPM, 14,400 RPD
# 如果經常遇到 429 錯誤，請調整這些值
LLM_CONCURRENT_LIMIT=2
LLM_REQUEST_DELAY=4
LLM_MAX_RETRIES=2
LLM_TIMEOUT=30

# --------------------------------------------
# RSS Configuration (選填)
# --------------------------------------------
# 抓取文章的天數範圍
RSS_FETCH_DAYS=7

# --------------------------------------------
# Scheduler Configuration (選填)
# --------------------------------------------
# CRON 表達式範例:
#   "0 */6 * * *"   - 每 6 小時
#   "0 0 * * *"     - 每天午夜
#   "0 9 * * 1"     - 每週一早上 9 點
#   "*/30 * * * *"  - 每 30 分鐘
SCHEDULER_CRON=0 */6 * * *
SCHEDULER_TIMEZONE=Asia/Taipei

# --------------------------------------------
# Batch Processing Configuration (選填)
# --------------------------------------------
BATCH_SIZE=50
BATCH_SPLIT_THRESHOLD=100

# --------------------------------------------
# JWT Configuration (必填)
# --------------------------------------------
# 產生強密鑰: openssl rand -hex 32
# 至少 32 字元！
JWT_SECRET=your_jwt_secret_at_least_32_characters_long_please_change_this_immediately
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DAYS=7

# --------------------------------------------
# CORS Configuration (必填)
# --------------------------------------------
# 開發: http://localhost:3000
# 正式: https://yourdomain.com
# 多個來源用逗號分隔: http://localhost:3000,https://yourdomain.com
CORS_ORIGINS=http://localhost:3000

# --------------------------------------------
# Rate Limiting Configuration (選填)
# --------------------------------------------
RATE_LIMIT_PER_MINUTE_UNAUTH=100
RATE_LIMIT_PER_MINUTE_AUTH=300

# --------------------------------------------
# Security Configuration (必填)
# --------------------------------------------
# 開發環境: false
# 正式環境: true (需要 HTTPS)
COOKIE_SECURE=false

# --------------------------------------------
# Frontend URL Configuration (必填)
# --------------------------------------------
# OAuth 登入後的重定向目標
# 開發: http://localhost:3000
# 正式: https://yourdomain.com
# 注意: 這是後端用來重定向的 URL，必須與前端實際部署的網址一致
FRONTEND_URL=http://localhost:3000

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# --------------------------------------------
# API Configuration (必填)
# --------------------------------------------
# 開發: http://localhost:8000
# 正式: https://api.yourdomain.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --------------------------------------------
# Application Configuration (必填)
# --------------------------------------------
NEXT_PUBLIC_APP_NAME=Tech News Agent

# 開發: http://localhost:3000
# 正式: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# 注意事項
# ============================================
#
# 1. NEXT_PUBLIC_* 變數會暴露在前端，不要放敏感資訊
# 2. Backend 變數 (SUPABASE_KEY, DISCORD_TOKEN 等) 只在後端使用
# 3. 正式環境務必:
#    - 使用強隨機的 JWT_SECRET
#    - 設定 COOKIE_SECURE=true
#    - 使用 HTTPS
#    - 更新 CORS_ORIGINS 為實際網域
# 4. 不要提交 .env 到 Git！
#
# ============================================
